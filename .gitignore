# EcoTrack Git Exclude Rules
# This file prevents local cache and build assets from being tracked.

# 1. Dependency Cache
# Avoid uploading node packages as they can be re-installed from package.json
node_modules/

# 2. Production Bundles
# Exclude the compiled production assets directory generated by Vite
dist/
dist-ssr/

# 3. Environment Variables & Secret Sandboxes
# Prevent local configurations or variables from leak
*.local
.env
.env.*

# 4. Debug Logs
# Ignore npm/yarn run crash logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 5. OS and IDE Directories
# Ignore local IDE/system specific configuration caches
.idea/
.vscode/
.DS_Store
Thumbs.db
